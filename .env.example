# Anthropic API key, read by the Anthropic SDK in api/*.ts. Required for all
# three AI endpoints (generate-lesson, generate-questions, generate-assessment).
ANTHROPIC_API_KEY=

# Shared-secret gate for the AI endpoints (api/generate-lesson.ts,
# api/generate-questions.ts, api/generate-assessment.ts). Server-only — read
# via process.env, never exposed to the client bundle directly. Requests
# missing/mismatching the x-mk-api-key header are rejected with 401.
#
# NOTE: this is a deterrent against drive-by abuse of the bare URL, not a
# true secret. The client must send this same value back from a build-time
# Vite var (VITE_MK_API_KEY, below), which Vite inlines as plain text into
# the shipped JS bundle — anyone who opens devtools can read it. It stops
# scrapers/scripts that find the URL without loading the app; it does not
# stop someone who copies the header out of a real browser request. Set
# MK_API_SECRET and VITE_MK_API_KEY to the SAME value.
MK_API_SECRET=

# Vite-exposed copy of MK_API_SECRET, baked into the client bundle at build
# time so the browser can send it as the x-mk-api-key header. Must match
# MK_API_SECRET exactly. See the caveat above — set in Vercel for both
# Production and Preview environments.
VITE_MK_API_KEY=

# Optional: tune the per-IP token-bucket rate limiter (api/_lib/rate-limit.ts).
# Defaults: 10 requests per 60s window per IP. This is in-memory and resets
# on cold start / isn't shared across instances — see the comment in
# rate-limit.ts for what to provision (Vercel KV or Upstash Redis) for a
# durable, cross-instance limit.
MK_RATE_LIMIT_MAX=10
MK_RATE_LIMIT_WINDOW_MS=60000
